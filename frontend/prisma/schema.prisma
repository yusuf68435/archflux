generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============ AUTH & USERS ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  role          Role      @default(USER)
  locale        String    @default("en")
  theme         Theme     @default(SYSTEM)
  credits       Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  jobs           Job[]
  transactions   CreditTransaction[]
  refundRequests RefundRequest[]
}

enum Role {
  USER
  ADMIN
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ CREDITS ============

model CreditPackage {
  id        String  @id @default(cuid())
  name      String
  credits   Int
  priceTRY  Float
  priceUSD  Float?
  active    Boolean @default(true)
  sortOrder Int     @default(0)
}

model CreditTransaction {
  id          String          @id @default(cuid())
  userId      String
  amount      Int
  balance     Int
  type        TransactionType
  description String?
  jobId       String?
  paymentRef  String?
  createdAt   DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])
  job  Job? @relation(fields: [jobId], references: [id])
}

enum TransactionType {
  PURCHASE
  USAGE
  REFUND
  ADMIN_GRANT
  ADMIN_REVOKE
  BONUS
}

// ============ JOBS ============

model Job {
  id              String    @id @default(cuid())
  userId          String
  type            JobType
  status          JobStatus @default(PENDING)
  creditsCost     Int

  // Input
  inputImageUrl   String
  inputImageMeta  Json?
  cropRegion      Json?
  splitConfig     Json?
  detailRegion    Json?
  codingConfig    Json?

  // Output
  outputDxfUrl     String?
  outputPreviewUrl String?
  outputMeta       Json?

  // Processing
  celeryTaskId String?
  progress     Int       @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User               @relation(fields: [userId], references: [id])
  transactions  CreditTransaction[]
  refundRequest RefundRequest?
}

enum JobType {
  FULL_CONVERSION
  PARTIAL_SPLIT
  DETAIL_EXTRACTION
  AUTO_CODING
}

enum JobStatus {
  PENDING
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// ============ REFUNDS ============

model RefundRequest {
  id         String       @id @default(cuid())
  jobId      String       @unique
  userId     String
  reason     String       @db.Text
  status     RefundStatus @default(PENDING)
  adminNote  String?      @db.Text
  resolvedAt DateTime?
  createdAt  DateTime     @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}
